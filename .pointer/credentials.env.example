# Template for .pointer/credentials.env (which is gitignored — copy this file to
# credentials.env and fill in the secret). Used by the pointer-feedback apply skill.
#
#   cp .pointer/credentials.env.example .pointer/credentials.env
#   # then set POINTER_PASSWORD (and POINTER_EMAIL if your account differs)

# Target Pointer API + project (not secret).
POINTER_SERVER=https://api.pointer.moamen.work
POINTER_PROJECT=pointer-landing

# Automation account on the PRODUCTION Pointer API. Keep the password out of git.
POINTER_EMAIL=automation@pointer.local
POINTER_PASSWORD=
