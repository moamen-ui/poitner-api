# Copy to .env.prod (gitignored) and fill in real values, then:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
# Generate secrets with e.g. `openssl rand -hex 32`.

# Postgres password (used by both db and api).
DB_PASSWORD=change-me

# JWT HS256 signing key — must be >= 32 chars.
JWT_SIGNING_KEY=change-me-to-a-long-random-string

# Seeded admin account (created on first boot). Change the password!
ADMIN_EMAIL=admin@pointer.local
ADMIN_PASSWORD=change-me

# Public API origin — used to build embed.js / served-skill URLs (no trailing slash).
POINTER_SERVER=https://api.pointer.moamen.work

# Transactional email (Brevo). Leave EMAIL_ENABLED=false until the domain/sender is
# verified in Brevo and DNS (SPF/DKIM) is set — otherwise sends are skipped (no-op).
#   EMAIL_FROM_EMAIL must be a Brevo-verified sender/domain.
#   Per-day send cap is the AppSetting "email_daily_cap" (default 250, < Brevo's 300/day).
EMAIL_ENABLED=false
EMAIL_API_KEY=
EMAIL_FROM_EMAIL=no-reply@pointer.moamen.work
EMAIL_FROM_NAME=Pointer
